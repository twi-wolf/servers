# Server-Wolf Environment Variables
# Copy this to .env and fill in your values

# Port (Heroku sets this automatically — do not set manually on Heroku)
PORT=3001

# Node environment
NODE_ENV=production

# Optional: Session secret for future auth hardening
SESSION_SECRET=change_me_to_a_random_string

# Optional: CORS origin whitelist (comma-separated, or * for all)
# CORS_ORIGIN=https://your-app.herokuapp.com
